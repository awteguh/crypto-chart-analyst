# Pilih salah satu (atau beberapa). Urutan prioritas: Gemini → OpenRouter → Claude → rule-based.

# Google Gemini (GRATIS) — dapat di https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter — akses 100+ model (Claude, GPT, Gemini, dll.) via satu API key
# Daftar di https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Model default OpenRouter (opsional, default: google/gemma-4-31b-it:free)
# Model gratis dengan vision support (Juni 2026): google/gemma-4-31b-it:free, nvidia/nemotron-nano-12b-v2-vl:free
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Anthropic Claude (berbayar) — dapat di https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
